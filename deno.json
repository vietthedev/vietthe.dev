{
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build:web": "vite build",
    "build:assets": {
      "command": "cp -r data _fresh/client",
      "dependencies": ["build:web"]
    },
    "build": {
      "dependencies": ["build:web", "build:assets"]
    },
    "start": "deno serve --allow-all _fresh/server.js",
    "update": "deno run --allow-all --reload jsr:@fresh/update .",
    "test": "deno test --allow-read"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@deno/gfm": "jsr:@deno/gfm@0.12.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
    "@preact-icons/tb": "jsr:@preact-icons/tb@1.0.14",
    "@preact/signals": "npm:@preact/signals@2.9.2",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@0.225.7",
    "@std/front-matter": "jsr:@std/front-matter@1.0.9",
    "@std/http": "jsr:@std/http@1.1.1",
    "@std/path": "jsr:@std/path@1.1.5",
    "@std/testing": "jsr:@std/testing@1.0.19",
    "@tailwindcss/typography": "npm:/@tailwindcss/typography@0.5.15",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.3.0",
    "daisyui": "npm:daisyui@5.5.23",
    "preact": "npm:preact@10.29.3",
    "tailwindcss": "npm:tailwindcss@4.3.0",
    "tailwindcss/": "npm:/tailwindcss@4.3.0/",
    "tailwindcss/plugin": "npm:/tailwindcss@4.3.0/plugin.js",
    "fresh": "jsr:@fresh/core@2.3.3",
    "vite": "npm:vite@7.3.6",
    "wrangler": "npm:wrangler@4.105.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "nodeModulesDir": "auto"
}
