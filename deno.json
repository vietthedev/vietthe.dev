{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "start": "vite",
    "build": "vite build",
    "preview": "deno serve -allow-all _fresh/server.js",
    "update": "deno run --allow-all --reload https://fresh.deno.dev/update .",
    "test": "deno test --allow-read"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@deno/gfm": "jsr:@deno/gfm@0.12.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
    "@preact/signals": "npm:@preact/signals@2.9.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@0.225.7",
    "@std/front-matter": "jsr:@std/front-matter@1.0.9",
    "@std/http": "jsr:@std/http@1.1.1",
    "@std/path": "jsr:@std/path@1.1.5",
    "@std/testing": "jsr:@std/testing@1.0.19",
    "@tailwindcss/typography": "npm:/@tailwindcss/typography@0.5.15",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.3.0",
    "daisyui": "npm:daisyui@5.5.20",
    "preact": "npm:preact@10.29.1",
    "preact/": "https://esm.sh/preact@10.24.3/",
    "tabler_icons_tsx/": "https://deno.land/x/tabler_icons_tsx@0.0.7/tsx/",
    "tailwindcss": "npm:tailwindcss@4.3.0",
    "tailwindcss/": "npm:/tailwindcss@4.3.0/",
    "tailwindcss/plugin": "npm:/tailwindcss@4.3.0/plugin.js",
    "fresh": "jsr:@fresh/core@2.3.3",
    "vite": "npm:vite@8.0.16",
    "wrangler": "npm:wrangler@4.101.0"
  },
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" },
  "nodeModulesDir": "auto"
}
