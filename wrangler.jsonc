{
  "$schema": "https://unpkg.com/wrangler@4.106.0/config-schema.json",
  "assets": {
    "directory": "_fresh/client"
  },
  "build": {
    "command": "bash ./scripts/deploy.sh"
  },
  "compatibility_date": "2026-07-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./server.js",
  "name": "vietthedev",
  "workers_dev": false
}
