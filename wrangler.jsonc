{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vietthedev",
  "compatibility_date": "2026-06-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "deno install && deno task build"
  },
  "assets": {
    "directory": "_fresh/client"
  },
  "main": "./server.js"
}
